{
  "name": "image-audit",
  "version": "1.0.2",
  "description": "Find and remove unused images in your project. Vite & Webpack plugin with visual HTML report. Supports Vue, React, and any web project.",
  "type": "module",
  "license": "MIT",
  "author": "Cyran <790707712@qq.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Cyran777/image-audit.git"
  },
  "bugs": {
    "url": "https://github.com/Cyran777/image-audit/issues"
  },
  "homepage": "https://github.com/Cyran777/image-audit#readme",
  "keywords": [
    "unused-images",
    "image-cleaner",
    "image-audit",
    "vite-plugin",
    "webpack-plugin",
    "image-optimizer",
    "image-minimizer",
    "assets-cleanup",
    "vue",
    "react",
    "images",
    "assets",
    "bundle-size",
    "devtools",
    "developer-tools"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "import": "./dist/vite.js"
    },
    "./webpack": {
      "types": "./dist/webpack.d.ts",
      "import": "./dist/webpack.js"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "image-audit": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "vite": ">=4.0.0",
    "webpack": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    },
    "webpack": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsup": "^8.4.0",
    "typescript": "^5.8.2",
    "vite": "^6.2.2",
    "webpack": "^5.98.0"
  },
  "engines": {
    "node": ">=18"
  }
}
